# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Olostep (scraping eBay + Etsy search results)
OLOSTEP_API_KEY=your-olostep-api-key

# OpenAI (optional — only needed if ENABLE_AI_SCORING=true)
OPENAI_API_KEY=your-openai-api-key

# Scoring mode: keyword heuristics by default, LLM scorer when true
# ENABLE_AI_SCORING=true

# Vercel Cron secret (authenticates both the daily cron and manual sync)
# CRON_SECRET=your-cron-secret

# Client-side sync secret (must match CRON_SECRET — allows the UI to trigger sync)
# NEXT_PUBLIC_SYNC_SECRET=your-cron-secret
